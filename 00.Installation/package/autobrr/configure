#!/bin/bash
#
# https://github.com/Aniverse/inexistence
# Author: Aniverse
#
script_update=2026.03.06
script_version=r10001

################################################################################################ Debug

usage_for_debug() {
    export local_packages=/etc/inexistence/00.Installation
    export s=$local_packages/package/autobrr/configure
    rm -f $s ; nano $s
    bash $s --user aniverse --password password
}

################################################################################################ Get options

unset LogBase LogTimes SCLocation DebLocation LogLocation LOCKLocation OutputLOG \
      AppName AppNameLower Need_SourceCode pm_action \
      user password debug

AppName=autobrr
AppNameLower=autobrr
Need_SourceCode=no
pm_action=configure

function show_usage() { echo "
$AppName $pm_action $script_version ($script_update)
Usage:
      -u        User to configure autobrr for
      -p        Password for autobrr web UI
      -d        Enable debug mode
"
exit 1 ; }

OPTS=$(getopt -o u:p:d -al user:,password:,debug,log -- "$@")
[ ! $? = 0 ] && show_usage
eval set -- "$OPTS"

while [ -n "$1" ] ; do case "$1" in
    -u | --user        ) user="$2"     ; shift 2 ;;
    -p | --password    ) password="$2" ; shift 2 ;;
    -d | --debug       ) debug=1       ; shift   ;;
         --log         ) show_log=1    ; shift   ;;
         --            ) shift         ; break   ;;
esac ; done

################################################################################################ Set Variables 1

if [[ -f /etc/inexistence/00.Installation/function ]]; then
    source /etc/inexistence/00.Installation/function
else
    source <(wget -qO- https://github.com/Aniverse/inexistence/raw/master/00.Installation/function)
fi

set_variables_log_location
check_var_OutputLOG
debug_log_location
cat_outputlog

################################################################################################ Set Variables 2

[[ -z $user ]] && user=$iUser
[[ -z $password ]] && password=$iPass

iHome=$(eval echo "~$user")
autobrr_config="$iHome/.config/autobrr"
autobrr_config_file="$autobrr_config/config.toml"

################################################################################################ Functions

function configure_autobrr_webui() {
    lines2 >> $OutputLOG
    echo_task "Configuring autobrr web UI ..."

    # Create config directory
    mkdir -p $autobrr_config >> $OutputLOG 2>&1
    chown -R $user:$user $autobrr_config >> $OutputLOG 2>&1

    # Generate session secret
    session_secret=$(openssl rand -hex 32)

    # Create config file
    cat << EOF > $autobrr_config_file
# autobrr configuration
# Generated by inexistence script

host = "0.0.0.0"
port = 7474
base_url = "/"
session_secret = "$session_secret"

[database]
type = "sqlite"

[log]
level = "INFO"
path = "$autobrr_config/logs"
max_size = 10
max_backups = 5

[update]
check_for_updates = true
EOF

    chown $user:$user $autobrr_config_file >> $OutputLOG 2>&1
    chmod 600 $autobrr_config_file >> $OutputLOG 2>&1

    status_done
}

function create_autobrr_admin_user() {
    lines2 >> $OutputLOG
    echo_task "Creating autobrr admin user ..."

    # Start autobrr temporarily to create user
    systemctl start autobrr@$user >> $OutputLOG 2>&1
    sleep 3

    # Create admin user using autobrrctl
    autobrrctl --config $autobrr_config create-user --username $user --password "$password" >> $OutputLOG 2>&1

    if [[ $? == 0 ]]; then
        status_done
        echo_info "Admin user '$user' created successfully"
    else
        echo_error "Failed to create admin user"
        return 1
    fi
}

function setup_autobrr_directories() {
    lines2 >> $OutputLOG
    echo_task "Setting up autobrr directories ..."

    # Create necessary directories
    mkdir -p $autobrr_config/logs >> $OutputLOG 2>&1
    mkdir -p $autobrr_config/data >> $OutputLOG 2>&1

    chown -R $user:$user $autobrr_config >> $OutputLOG 2>&1

    status_done
}

function configure_autobrr_permissions() {
    lines2 >> $OutputLOG
    echo_task "Setting up permissions ..."

    # Set proper permissions
    chmod 750 $autobrr_config >> $OutputLOG 2>&1
    chmod 640 $autobrr_config_file >> $OutputLOG 2>&1

    status_done
}

function print_autobrr_info() {
    echo
    echo "╔════════════════════════════════════════╗"
    echo "║         autobrr Configuration         ║"
    echo "╚════════════════════════════════════════╝"
    echo
    echo "Web UI:     http://your-server-ip:7474"
    echo "Username:   $user"
    echo "Password:   $password"
    echo "Config:     $autobrr_config_file"
    echo
    echo "Service Management:"
    echo "  Start:   systemctl start autobrr@$user"
    echo "  Stop:    systemctl stop autobrr@$user"
    echo "  Restart: systemctl restart autobrr@$user"
    echo "  Status:  systemctl status autobrr@$user"
    echo
    echo "Documentation: https://autobrr.com"
    echo
}

################################################################################################ Main

configure_autobrr_webui
setup_autobrr_directories
configure_autobrr_permissions
create_autobrr_admin_user

print_autobrr_info

echo
echo "autobrr configuration completed!"
echo
